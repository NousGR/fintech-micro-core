generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum AccountType {
  CHECKING
  SAVINGS
  WALLET
}

enum AccountStatus {
  ACTIVE
  FROZEN
  CLOSED
}

enum Currency {
  PEN
  USD
  EUR
}

enum TransferStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

enum TransactionType {
  DEBIT
  CREDIT
}

model User {
  id             String     @id @default(uuid()) @db.Uuid
  email          String     @unique @db.VarChar(255)
  passwordHash   String     @db.VarChar(255)
  documentNumber String?    @unique @db.VarChar(32)
  firstName      String     @db.VarChar(100)
  lastName       String     @db.VarChar(100)
  phone          String?    @unique @db.VarChar(32)
  status         UserStatus @default(ACTIVE)

  accounts           Account[]
  initiatedTransfers Transfer[] @relation("InitiatedTransfers")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status])
  @@map("users")
}

model Account {
  id            String        @id @default(uuid()) @db.Uuid
  userId        String        @db.Uuid
  accountNumber String        @unique @db.VarChar(30)
  type          AccountType   @default(WALLET)
  status        AccountStatus @default(ACTIVE)
  currency      Currency      @default(PEN)
  balance       Decimal       @default(0) @db.Decimal(19, 4)

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  outgoingTransfers Transfer[]    @relation("OutgoingTransfers")
  incomingTransfers Transfer[]    @relation("IncomingTransfers")
  transactions      Transaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([currency])
  @@map("accounts")
}

model Transfer {
  id                String         @id @default(uuid()) @db.Uuid
  fromAccountId     String         @db.Uuid
  toAccountId       String         @db.Uuid
  initiatedByUserId String?        @db.Uuid
  amount            Decimal        @db.Decimal(19, 4)
  currency          Currency       @default(PEN)
  status            TransferStatus @default(PENDING)
  description       String?        @db.VarChar(255)
  idempotencyKey    String?        @unique @db.VarChar(100)

  fromAccount Account @relation("OutgoingTransfers", fields: [fromAccountId], references: [id], onDelete: Restrict)
  toAccount   Account @relation("IncomingTransfers", fields: [toAccountId], references: [id], onDelete: Restrict)

  initiatedBy User? @relation("InitiatedTransfers", fields: [initiatedByUserId], references: [id], onDelete: SetNull)

  transactions Transaction[]

  createdAt   DateTime  @default(now())
  processedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@index([fromAccountId])
  @@index([toAccountId])
  @@index([initiatedByUserId])
  @@index([status])
  @@index([createdAt])
  @@map("transfers")
}

model Transaction {
  id           String          @id @default(uuid()) @db.Uuid
  accountId    String          @db.Uuid
  transferId   String?         @db.Uuid
  type         TransactionType
  amount       Decimal         @db.Decimal(19, 4)
  currency     Currency        @default(PEN)
  balanceAfter Decimal         @db.Decimal(19, 4)
  description  String?         @db.VarChar(255)

  account  Account   @relation(fields: [accountId], references: [id], onDelete: Restrict)
  transfer Transfer? @relation(fields: [transferId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([accountId, createdAt])
  @@index([transferId])
  @@index([type])
  @@map("transactions")
}
